/******************************************************************************/
/**************************** EDIT LECTURE VIDEOS  ****************************/
/******************************************************************************/
function edit_lecture_videos_form($form, &$form_state)
{
    $user = \Drupal::currentUser();
    /* get current proposal */
    $video_id = (int) arg (2);
    //$proposal_q = db_query("SELECT * FROM {research_migration_proposal} WHERE id = %d", $proposal_id);
    $query = \Drupal::database()->select('lecture_videos');
    $query->fields('lecture_videos');
    $query->condition('id', $video_id);
    $lecture_video_q = $query->execute();
    $lecture_video_data = $lecture_video_q->fetchObject();
    //var_dump($lecture_video_data);die;

    $form['video_sno'] = array(
        '#type' => 'textfield',
        '#title' => t('S.No of the video'),
        '#required' => true,
        '#disabled' => True,
        '#default_value' => $lecture_video_data->video_sno,
    );

    $form['title_of_video'] = array(
        '#type' => 'textfield',
        '#title' => t('Title of the video lecture'),
        // '#size' => 30,
        // '#maxlength' => 50,
        '#required' => true,
        '#default_value' => $lecture_video_data->video_title,
    );
   
    $form['description_of_video'] = array(
        '#type' => 'text_format',
        '#format' => $lecture_video_data->video_description_text_format,
        '#title' => 'Description of the video',
        '#required' => TRUE,
        '#default_value'=> $lecture_video_data->video_description_text,
    );
    $form['link_to_video'] = array(
        '#type' => 'textfield',
        "#title" => "Paste the URL of the video lecture",
        '#size' => 255,
        '#maxlength' => 255,
        '#required' => TRUE,
        '#default_value'=> $lecture_video_data->video_link,
    );
    $form["link_to_script_file"] = array(
        "#type" => "textfield",
        "#title" => "Paste the URL of the script file  of the video lecture",
       
        '#size' => 255,
        '#maxlength' => 255,
        '#required' =>TRUE,
        '#default_value'=> $lecture_video_data->script_file_link,
    );
    //var_dump($lecture_video_data->video_visibility);die;
    $form['lecture_visibility'] = array(
        '#type' => 'select',
        '#title' => t('Do you want to disable this lecture?'),
        '#default_value'=> t($lecture_video_data->video_visibility),
        '#options' => array(
            'Y' => t('Yes'),
            'N'  => t('No')
        ),
        '#required' => TRUE,
    ); 
    $form["submit"] = array(
        "#type" => "submit",
        "#value" => "Submit"
    );
    
    return $form;
}

function edit_lecture_videos_form_submit($form, &$form_state) {
    $v = $form_state['values'];
    $query = "UPDATE lecture_videos SET
            video_title = :video_title,
            video_description_text = :video_description_text,
            video_description_text_format = :video_description_text_format,
            script_file_link = :script_file_link,
            video_link = :video_link,
            video_visibility = :video_visibility
            WHERE video_sno = :video_sno";
    $args = array(
        ":video_title" => $v['title_of_video'],
        ":video_description_text" => $v['description_of_video']['value'],
        ":video_description_text_format" => $v['description_of_video']['format'],
        ":script_file_link" => $v['link_to_script_file'],
        ":video_link" => $v['link_to_video'],
        ":video_visibility" => $v['lecture_visibility'],
        ":video_sno" => $v['video_sno']
    );
    $result= \Drupal::database()->query($query, $args);
    \Drupal::messenger()->addStatus('Video details updated successfully');
    drupal_goto('lecture-videos/manage');
}

/**
 * Implements hook_mail().
 */
function esim_research_migration_mail($key, &$message, $params) {
    $site_name = Html::escape((string) \Drupal::config('system.site')->get('name'));
    $message['body'] = $message['body'] ?? [];

    switch ($key) {
        case 'research_migration_proposal_received': {
            $proposal_id = $params['research_migration_proposal_received']['result1'] ?? NULL;
            $user_id = $params['research_migration_proposal_received']['user_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $user = $user_id ? \Drupal::entityTypeManager()->getStorage('user')->load($user_id) : NULL;
            $message['headers'] = $params['research_migration_proposal_received']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your Research Migration Project proposal has been received', ['@site_name' => $site_name]);
            if ($proposal_data && $user) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('We have received your Research Migration Project proposal with the following details:');
                $message['body'][] = t('Full Name: @full_name', ['@full_name' => $proposal_data->name_title . ' ' . $proposal_data->contributor_name]);
                $message['body'][] = t('Email: @email', ['@email' => $user->getEmail()]);
                $message['body'][] = t('University/Institute: @university', ['@university' => $proposal_data->university]);
                $message['body'][] = t('City: @city', ['@city' => $proposal_data->city]);
                $message['body'][] = t('State: @state', ['@state' => $proposal_data->state]);
                $message['body'][] = t('Country: @country', ['@country' => $proposal_data->country]);
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                $message['body'][] = t('Date of Proposal: @date', ['@date' => date('d/m/Y', $proposal_data->creation_date)]);
                $message['body'][] = t('Expected Date of Completion: @date', ['@date' => date('d/m/Y', $proposal_data->expected_date_of_completion)]);
                $message['body'][] = '';
                $message['body'][] = t('Your proposal is under review. You will soon receive an email when it has been approved or disapproved.');
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'research_migration_proposal_approved': {
            $proposal_id = $params['research_migration_proposal_approved']['proposal_id'] ?? NULL;
            $user_id = $params['research_migration_proposal_approved']['user_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $user = $user_id ? \Drupal::entityTypeManager()->getStorage('user')->load($user_id) : NULL;
            $message['headers'] = $params['research_migration_proposal_approved']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your Research Migration Project proposal has been approved', ['@site_name' => $site_name]);
            $url = \Drupal::request()->getSchemeAndHttpHost() . '/research-migration-project/abstract-code';
            if ($proposal_data && $user) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('Your Research Migration Project proposal has been approved.');
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                $message['body'][] = '';
                $message['body'][] = t('You can upload your project files at: @url', ['@url' => $url]);
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'research_migration_proposal_disapproved': {
            $proposal_id = $params['research_migration_proposal_disapproved']['proposal_id'] ?? NULL;
            $user_id = $params['research_migration_proposal_disapproved']['user_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $user = $user_id ? \Drupal::entityTypeManager()->getStorage('user')->load($user_id) : NULL;
            $message['headers'] = $params['research_migration_proposal_disapproved']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your Research Migration Project proposal has been disapproved', ['@site_name' => $site_name]);
            if ($proposal_data && $user) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('We regret to inform you that your Research Migration Project proposal has been disapproved.');
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                if (!empty($proposal_data->dissapproval_reason)) {
                    $message['body'][] = t('Reason for rejection: @reason', ['@reason' => $proposal_data->dissapproval_reason]);
                }
                $message['body'][] = '';
                $message['body'][] = t('You are welcome to submit a new proposal.');
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'research_migration_proposal_completed': {
            $proposal_id = $params['research_migration_proposal_completed']['proposal_id'] ?? NULL;
            $user_id = $params['research_migration_proposal_completed']['user_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $message['headers'] = $params['research_migration_proposal_completed']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your Research Migration Project has been completed', ['@site_name' => $site_name]);
            if ($proposal_data) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('Your Research Migration Project has been completed successfully.');
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'research_migration_proposal_deleted': {
            $proposal_id = $params['research_migration_proposal_deleted']['proposal_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $message['headers'] = $params['research_migration_proposal_deleted']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your Research Migration Project proposal has been deleted', ['@site_name' => $site_name]);
            if ($proposal_data) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('Your Research Migration Project proposal has been deleted.');
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'abstract_uploaded': {
            $proposal_id = $params['abstract_uploaded']['proposal_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $message['headers'] = $params['abstract_uploaded']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] You have uploaded Research Migration Project files', ['@site_name' => $site_name]);
            if ($proposal_data) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('You have uploaded project files for the following Research Migration Project:');
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                $message['body'][] = '';
                $message['body'][] = t('Your files are under review. You will be notified when they have been approved.');
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'abstract_edit_file_uploaded': {
            $proposal_id = $params['abstract_edit_file_uploaded']['proposal_id'] ?? NULL;
            $proposal_data = $proposal_id ? \Drupal::database()->select('research_migration_proposal')->fields('research_migration_proposal')->condition('id', $proposal_id)->range(0, 1)->execute()->fetchObject() : NULL;
            $message['headers'] = $params['abstract_edit_file_uploaded']['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] You have updated project files/synopsis of a Research Migration', ['@site_name' => $site_name]);
            if ($proposal_data) {
                $message['body'][] = t('Dear @name,', ['@name' => $proposal_data->contributor_name]);
                $message['body'][] = '';
                $message['body'][] = t('You have updated the project files for the following Research Migration Project:');
                $message['body'][] = t('Project Title: @title', ['@title' => $proposal_data->project_title]);
                $message['body'][] = '';
                $message['body'][] = t('Best Wishes,');
                $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
                $message['body'][] = t('FOSSEE, IIT Bombay');
            }
            break;
        }

        case 'research_migration_abstract_bulk_approved': {
            $mail_data = $params['research_migration_abstract_bulk_approved'] ?? [];
            $name = (string) ($mail_data['contributor_name'] ?? 'Contributor');
            $title = (string) ($mail_data['project_title'] ?? '');
            $message['headers'] = $mail_data['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your uploaded Research Migration project has been approved', ['@site_name' => $site_name]);
            $message['body'][] = t('Dear @name,', ['@name' => $name]);
            $message['body'][] = '';
            $message['body'][] = t('Your uploaded project files for the Research Migration project have been approved.');
            if ($title !== '') {
                $message['body'][] = t('Project Title: @title', ['@title' => $title]);
            }
            $message['body'][] = '';
            $message['body'][] = t('Best Wishes,');
            $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
            $message['body'][] = t('FOSSEE, IIT Bombay');
            break;
        }

        case 'research_migration_abstract_bulk_resubmission': {
            $mail_data = $params['research_migration_abstract_bulk_resubmission'] ?? [];
            $name = (string) ($mail_data['contributor_name'] ?? 'Contributor');
            $title = (string) ($mail_data['project_title'] ?? '');
            $reason = trim((string) ($mail_data['reason'] ?? ''));
            $message['headers'] = $mail_data['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your uploaded Research Migration project has been marked for resubmission', ['@site_name' => $site_name]);
            $message['body'][] = t('Dear @name,', ['@name' => $name]);
            $message['body'][] = '';
            $message['body'][] = t('Your project files have been marked for resubmission. Please update your project files and resubmit.');
            if ($title !== '') {
                $message['body'][] = t('Project Title: @title', ['@title' => $title]);
            }
            if ($reason !== '') {
                $message['body'][] = t('Reason for resubmission: @reason', ['@reason' => $reason]);
            }
            $message['body'][] = '';
            $message['body'][] = t('Best Wishes,');
            $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
            $message['body'][] = t('FOSSEE, IIT Bombay');
            break;
        }

        case 'research_migration_abstract_bulk_disapproved': {
            $mail_data = $params['research_migration_abstract_bulk_disapproved'] ?? [];
            $name = (string) ($mail_data['contributor_name'] ?? 'Contributor');
            $title = (string) ($mail_data['project_title'] ?? '');
            $reason = trim((string) ($mail_data['reason'] ?? ''));
            $message['headers'] = $mail_data['headers'] ?? [];
            $message['subject'] = t('[@site_name][Research Migration Project] Your uploaded Research Migration project has been disapproved', ['@site_name' => $site_name]);
            $message['body'][] = t('Dear @name,', ['@name' => $name]);
            $message['body'][] = '';
            $message['body'][] = t('We regret to inform you that the project files submitted for the Research Migration project have been disapproved by the reviewer.');
            if ($title !== '') {
                $message['body'][] = t('Project Title: @title', ['@title' => $title]);
            }
            if ($reason !== '') {
                $message['body'][] = t('Reason for disapproval: @reason', ['@reason' => $reason]);
            }
            $message['body'][] = '';
            $message['body'][] = t('Best Wishes,');
            $message['body'][] = t('@site_name Team,', ['@site_name' => $site_name]);
            $message['body'][] = t('FOSSEE, IIT Bombay');
            break;
        }

        case 'standard': {
            $message['subject'] = $params['standard']['subject'] ?? '';
            $message['body'] = $params['standard']['body'] ?? [];
            $message['headers'] = $params['standard']['headers'] ?? [];
            break;
        }
    }
}
